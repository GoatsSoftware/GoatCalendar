# 1. Build
FROM python:3.13-slim as builder

# Update libs and install python pdm package
RUN apt update && apt upgrade && \
    python -m pip install --upgrade pip && \
    python -m pip install pdm

WORKDIR /app

# Set env variables
ENV PDM_CHECK_UPDATE=false

# Import service conf
COPY back/auth_service/pyproject.toml back/auth_service/pdm.lock .

# Install service dependancies
RUN pdm export --pyproject --prod --group prod --format requirements --output requirements.txt --no-hashes
RUN python -m pip install -r requirements.txt

# 2. Run
FROM python:3.13-slim as runner

WORKDIR /app/back

# Copy service libs
COPY --from=builder /usr/local/lib/python3.13/site-packages /usr/local/lib/python3.13/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy service source files
COPY back/auth_service /app/back/auth_service

WORKDIR /app/back/auth_service

# Copy env variables
RUN rm -f .env* && \
    echo 'ENV_MODE="prod"' > .env && \
    echo 'DB_DIALECT="mysql+aiomysql"' >> .env && \
    echo 'DB_URL="goatcalendar_user:goatcalendar_passwd@mysql-db:3306/goatcalendar_db"' >> .env && \
    echo 'SERVER_HOST="0.0.0.0"' >> .env && \
    echo 'SERVER_PORT=5001' >> .env && \
    echo 'FRONT_URL="front-service:80"' >> .env && \
    echo 'ENCRYPTION_KEY="q+b4dGwz4nZOjdoYvOwurO781EPliCKWxo0/2bTb7NeBN/lsybkh0EU+mWiefEtFtcIOrv0yZJHuakJQGYQz1Q=="' >> .env && \
    echo 'ACCESS_TOKEN_DURATION_MINUTES=1000' >> .env && \
    echo 'REFRESH_TOKEN_DURATION_HOURS=24' >> .env

EXPOSE 5001

ENV PYTHONPATH="/app/back/auth_service/src"

ENTRYPOINT ["fastapi", "run", "main.py"]
CMD ["--host", "0.0.0.0", "--port", "5001", "--workers", "4"]